{
  "name": "techscreen",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "AI-powered candidate interview tool",
  "scripts": {
    "test": "bun test",
    "dev": "wrangler dev",
    "dev:bun": "bun run src/server.ts",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply techscreen --local",
    "db:migrate": "wrangler d1 migrations apply techscreen --remote"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240000.0",
    "@types/bun": "latest",
    "drizzle-kit": "^0.28.0",
    "wrangler": "4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "drizzle-orm": "^0.36.0"
  }
}
