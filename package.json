{
  "name": "shortlink-demo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "DEMO URL shortener — pipeline walkthrough (TS/Bun, SQLite→D1 Workers).",
  "scripts": {
    "test": "bun test",
    "dev": "wrangler dev",
    "dev:bun": "bun run src/server.ts",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply shortlink --local",
    "db:migrate": "wrangler d1 migrations apply shortlink --remote"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240000.0",
    "@types/bun": "latest",
    "drizzle-kit": "^0.28.0",
    "wrangler": "4"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.0"
  }
}
